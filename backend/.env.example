# ============================================================
# RACE-Cloud Backend Configuration
# ============================================================
# Copy this file to .env and fill in values
# NEVER commit the .env file to version control
# ============================================================

# Flask
FLASK_SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_SECRET_KEY=change-this-to-another-random-secret-key

# Encryption key for AWS credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_ENCRYPTION_KEY=

# Database (filename only — stored inside backend/instance/)
DATABASE_PATH=racecloud.db

# CORS
FRONTEND_URL=http://localhost:3000

# JWT Token Expiry (hours)
JWT_ACCESS_TOKEN_EXPIRES=24

# ── Gemini AI ────────────────────────────────────────────────
# Required for AI-powered Decision Intelligence
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ── Email / SMTP Configuration ──────────────────────────────
# Used to email PDF reports to users after analysis
# For Gmail: enable "App Passwords" at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
